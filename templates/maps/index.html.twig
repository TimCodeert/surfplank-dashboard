{% extends 'base.html.twig' %}

{% block title %}SurfTimer Ranked Maps{% endblock %}

{% block body %}
<div class="container">
    <h1>Ranked Maps</h1>
    <p>Total ranked maps in pool: <strong>{{ maps|length }}</strong></p>

    <table class="leaderboard-table">
        <thead>
            <tr>
                <th>Map Name</th>
                <th>Tier</th>
                <th>Type</th>
                <th>Bonuses</th>
            </tr>
        </thead>
        <tbody>
            {% for map in maps %}
                <tr>
                    <td>
                        <a href="{{ path('app_map_times', { 'id': map.id }) }}" class="player-name-link">
                            <strong>{{ map.name }}</strong>
                        </a>
                    </td>
                    <td><span class="tag">Tier {{ map.tier ? map.tier : 1 }}</span></td>
                    <td>
                        {{ map.isLinear ? 'Linear' : map.stages ~ ' Stages' }}
                    </td>
                    <td>{{ map.bonuses }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8" class="no-results">No ranked maps found in the database.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}