{% extends 'base.html.twig' %}
{% import "_macros.html.twig" as ui %}

{% block title %}Leaderboard for {{ map.name }}{% endblock %}

{% block body %}
<div class="container">
    <h1>Leaderboard: {{ map.name }}</h1>
    <p>Type: {{ map.isLinear ? 'Linear' : 'Staged' }}</p>

    <table class="leaderboard-table">
        <thead>
            <tr>
                <th>Rank</th>
                <th>Player</th>
                <th>Time</th>
            </tr>
        </thead>
        <tbody>
            {% for time in times %}
                <tr>
                    <td>#{{ loop.index }}</td>
                    <td><strong>{{ time.player.name }} {{ ui.flag(time.player.country) }}</strong></td>
                    <td><code>{{ time.formattedTime }}</code></td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="no-results">No times recorded yet on this map.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}