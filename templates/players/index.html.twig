{% extends 'base.html.twig' %}

{% block title %}Active players{% endblock %}

{% block body %}
<div class="container">
    <h1>Active players</h1>
    <p>Total players: <strong>{{ players|length }}</strong></p>

    <table class="leaderboard-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Country</th>
                <th>Last Seen</th>
                <th>Visits</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for player in players %}
                <tr>
                    <td>
                        <a href="{{ path('app_player_times', { 'id': player.id }) }}" class="player-name-link">
                            <strong>{{ player.name }}</strong>
                        </a>
                    </td>
                    <td>
                        <div class="country-cell">
                            <img 
                                src="https://flagcdn.com/w20/{{ player.country|lower }}.png" 
                                srcset="https://flagcdn.com/w40/{{ player.country|lower }}.png 2x"
                                width="20" 
                                alt="{{ player.country }}">
                            <span>{{ player.country }}</span>
                        </div>
                    </td>
                    <td>{{ player.lastSeenAgo }}</td>
                    <td>{{ player.connections }}</td>
                    <td>
                        <a href="https://steamcommunity.com/profiles/{{ player.steamId }}/" 
                           target="_blank" 
                           rel="noopener noreferrer" 
                           class="steam-link">
                            
                            <img src="https://cdn.iconscout.com/icon/free/png-256/free-steam-logo-icon-svg-download-png-1933796.png" alt="Steam Logo">
                            <span>View Steam Profile</span>
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="no-results">No players found in the database.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}