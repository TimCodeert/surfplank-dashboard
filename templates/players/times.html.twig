{% extends 'base.html.twig' %}
{% import "_macros.html.twig" as ui %}

{% block title %}Profile {{ player.name }}{% endblock %}

{% block body %}
<div class="container" style="margin-top: 50px; font-family: sans-serif;">
    <div class="player-header">
        <div class="player-avatar-wrapper">
            {% if avatarUrl %}
                <img src="{{ avatarUrl }}" alt="{{ player.name }}" class="player-avatar">
            {% else %}
                <img src="https://avatars.steamstatic.com/fef49e7fa7e1997310d705b2a6158ff8dc1cdfeb_full.jpg" alt="Default Avatar" class="player-avatar">
            {% endif %}

            <span class="status-indicator {{ player.isOnline ? 'is-online' : 'is-offline' }}" 
                title="{{ player.isOnline ? 'Online' : 'Offline' }}">
            </span>
        </div>

        <div class="player-info">
            <div class="player-title-row">
                <h1 class="player-name">
                    {{ player.name }} {{ ui.flag(player.country) }}
                </h1>
            </div>

            <div class="player-stats-meta">
                <div class="meta-item">
                    <span class="meta-label">Status:</span>
                    {% if player.isOnline %}
                        <span class="status-badge online">In-Game</span>
                    {% else %}
                        <span class="status-badge offline">Last seen {{ player.lastSeenAgo }}</span>
                    {% endif %}
                </div>

                <span class="meta-divider">•</span>

                <div class="meta-item">
                    <span class="meta-label">Member since:</span>
                    <span class="meta-value">{{ player.joinDate|date('d/m/Y') }}</span>
                </div>

                <span class="meta-divider">•</span>

                <div class="meta-item">
                    <span class="meta-label">Visits:</span>
                    <span class="meta-value">{{ player.connections }}</span>
                </div>
            </div>

                            
                <a href="https://steamcommunity.com/profiles/{{ player.steamId }}" 
                target="_blank" 
                rel="noopener" 
                class="steam-link"
                title="View Steam Profile">
                <img src="https://cdn.iconscout.com/icon/free/png-256/free-steam-logo-icon-svg-download-png-1933796.png" alt="Steam Logo">
                </a>
        </div>
    </div>

    <h2>Maps</h2>
    <div class="tab-buttons">
        <button type="button" class="tab-btn active" data-tab="main">
            Main ({{ mainTimes|length }})
        </button>
        <button type="button" class="tab-btn" data-tab="bonus">
            Bonus ({{ bonusTimes|length }})
        </button>
        <button type="button" class="tab-btn" data-tab="uncompleted">
            Uncompleted ({{ uncompletedMaps|length }})
        </button>
    </div>

<div class="tab-content active" id="tab-main">
    <table class="leaderboard-table js-sortable-table">
        <thead>
            <tr>
                <th>Rank</th>
                <th>Map</th>
                <th>Type</th>
                <th>Time</th>
                <th>Diff WR</th>
                <th>Start</th>
                <th>End</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for time in mainTimes %}
                {% set rank = time.own.rankedData.worldwideRank %}
                {% set completions = time.own.rankedData.totalCompletions %}
                <tr>
                    <td>
                        <span style="font-weight: bold; color: {{ rank == 1 ? '#d4af37' : (rank == 2 ? '#aaa' : (rank == 3 ? '#cd7f32' : '#333')) }}">
                            #{{ rank }} / {{ completions }}
                        </span>
                    </td>
                    <td>
                        <a href="{{ path('app_map_times', { 'name': time.map.name }) }}" class="player-name-link">
                            <strong>{{ time.map.name }}</strong>
                        </a>
                    </td>
                    <td>
                        {{ time.map.isLinear ? 'Linear' : time.map.stages ~ ' Stages' }}
                    </td>
                    <td><code>{{ time.own.formattedTime }}</code></td>
                    <td><code>{{ ui.format_diff(time.own.runTime, time.WR) }}</code></td>
                    <td><code>{{ time.own.startSpeed }}u/s</code></td>
                    <td><code>{{ time.own.endSpeed }}u/s</code></td>
                    <td>
                    <div class="action-buttons">
                            <a href="{{ path('app_map_times', { 'name': time.map.name }) }}" 
                            class="action-btn" 
                            title="View map leaderboards"
                            aria-label="View map leaderboards">
                                🌍
                            </a>

                            <a href="{{ path('app_player_map_checkpoints', { 'name': time.map.name, 'steamId': player.steamId }) }}" 
                            class="action-btn" 
                            title="View checkpoints"
                            aria-label="View checkpoints">
                                🏁
                            </a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8" class="no-results">This player has not set any main times yet.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<div class="tab-content" id="tab-bonus" style="display: none;">
    <table class="leaderboard-table js-sortable-table">
        <thead>
            <tr>
                <th>Rank</th>
                <th>Map</th>
                <th>Stage #</th>
                <th>Time</th>
                <th>Start Speed</th>
                <th>End Speed</th>
            </tr>
        </thead>
        <tbody>
            {% for time in bonusTimes %}
                {% set rank = time.own.rankedData.worldwideRank %}
                {% set completions = time.own.rankedData.totalCompletions %}
                <tr>
                    <td>
                        <span style="font-weight: bold; color: {{ rank == 1 ? '#d4af37' : (rank == 2 ? '#aaa' : (rank == 3 ? '#cd7f32' : '#333')) }}">
                            #{{ rank }} / {{ completions }}
                        </span>
                    </td>
                    <td>
                        <a href="{{ path('app_map_times', { 'name': time.map.name }) }}" class="player-name-link">
                            <strong>{{ time.map.name }}</strong>
                        </a>
                    </td>
                    <td>{{ time.own.stage }}</td>
                    <td><code>{{ time.own.formattedTime }}</code></td>
                    <td>{{ time.own.startSpeed }}</td>
                    <td>{{ time.own.endSpeed }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="no-results">This player has not set any bonus times yet.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

    <div class="tab-content" id="tab-uncompleted" style="display: none;">
        <table class="leaderboard-table js-sortable-table">
            <thead>
                <tr>
                    <th>Map Name</th>
                    <th>Type</th>
                </tr>
            </thead>
            <tbody>
                {% for map in uncompletedMaps %}
                    <tr>
                        <td>
                            <a href="{{ path('app_map_times', { 'name': map.name }) }}" class="player-name-link">
                                <strong>{{ map.name }}</strong>
                            </a>
                        </td>
                        <td>
                            {% if map.isLinear %}
                                <span class="badge badge-linear">Linear</span>
                            {% else %}
                                <span class="badge badge-staged">Staged</span>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <h2>Achievements</h2>
    <div class="achievements-grid">
        {% for achievement in achievements %}
            {% set isUnlocked = achievement.key in unlockedKeys %}
            
            <div class="achievement-card {{ isUnlocked ? 'unlocked' : 'locked' }}">
                <div class="achievement-badge-container">
                <img src="{{ asset('images/achievements/' ~ achievement.key ~ '.png') }}" alt="{{ achievement.name }}" class="achievement-img">
                    
                    {% if not isUnlocked %}
                        <div class="lock-overlay">🔒</div>
                    {% endif %}
                </div>
                
                <h3>{{ achievement.name }}</h3>
                <p>{{ achievement.description }}</p>
            </div>
        {% endfor %}
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const buttons = document.querySelectorAll('.tab-btn');
        const contents = document.querySelectorAll('.tab-content');

        buttons.forEach(button => {
            button.addEventListener('click', function () {
                const targetTab = this.getAttribute('data-tab');
                buttons.forEach(btn => btn.classList.remove('active'));
                contents.forEach(content => content.style.display = 'none');
                this.classList.add('active');
                document.getElementById('tab-' + targetTab).style.display = 'block';
            });
        });
    });
</script>
{% endblock %}