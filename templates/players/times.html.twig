{% extends 'base.html.twig' %}
{% import "_macros.html.twig" as ui %}

{% block title %}Profile {{ player.name }}{% endblock %}

{% block body %}
<div class="container" style="margin-top: 50px; font-family: sans-serif;">
    <h1>{{ player.name }} {{ ui.flag(player.country) }}</h1>
    <h2>Main map</h2>
    <table class="leaderboard-table js-sortable-table">
        <thead>
            <tr>
                <th>Rank</th>
                <th>Map</th>
                <th>Stage</th>
                <th>Time</th>
                <th>Diff WR</th>
                <th>Start Speed</th>
                <th>End Speed</th>
                <th>Checkpoints</th>
            </tr>
        </thead>
        <tbody>
            {% for time in mainTimes %}
                {% set rank = time.own.rankedData.worldwideRank %}
                {% set completions = time.own.rankedData.totalCompletions %}

                <tr>
                    <td>
                        <span style="font-weight: bold; color: {{ rank == 1 ? '#d4af37' : (rank == 2 ? '#aaa' : (rank == 3 ? '#cd7f32' : '#333')) }}">
                            #{{ rank }} / {{ completions }}
                        </span>
                    </td>
                    <td>
                        <a href="{{ path('app_map_times', { 'name': time.map.name }) }}" class="player-name-link">
                            <strong>{{ time.map.name }}</strong>
                        </a>
                    </td>
                    <td>
                        {{ time.map.isLinear ? 'Linear' : time.map.stages ~ ' Stages' }}
                    </td>
                    <td><code>{{ time.own.formattedTime }}</code></td>
                    <td><code>{{ ui.format_diff(time.own.runTime, time.WR) }}</code></td>
                    <td>{{ time.own.startSpeed }}</td>
                    <td>{{ time.own.endSpeed }}</td>
                    <td>
                        <a href="{{ path('app_player_map_checkpoints', { 'name': time.map.name, 'steamId': player.steamId }) }}" class="player-name-link">
                            See checkpoints
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="no-results">This player has not set any times yet.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <h2>Bonus</h2>
    <table class="leaderboard-table js-sortable-table">
        <thead>
            <tr>
                <th>Rank</th>
                <th>Map</th>
                <th>Stage #</th>
                <th>Time</th>
                <th>Start Speed</th>
                <th>End Speed</th>
            </tr>
        </thead>
        <tbody>
            {% for time in bonusTimes %}
                {% set rank = time.own.rankedData.worldwideRank %}
                {% set completions = time.own.rankedData.totalCompletions %}

                <tr>
                    <td>
                        <span style="font-weight: bold; color: {{ rank == 1 ? '#d4af37' : (rank == 2 ? '#aaa' : (rank == 3 ? '#cd7f32' : '#333')) }}">
                            #{{ rank }} / {{ completions }}
                        </span>
                    </td>
                    <td>
                        <a href="{{ path('app_map_times', { 'name': time.map.name }) }}" class="player-name-link">
                            <strong>{{ time.map.name }}</strong>
                        </a>
                    </td>
                    <td>
                        {{ time.own.stage }}
                    </td>
                    <td><code>{{ time.own.formattedTime }}</code></td>
                    <td>{{ time.own.startSpeed }}</td>
                    <td>{{ time.own.endSpeed }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="no-results">This player has not set any times yet.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>


    {% if uncompletedMaps is not empty %}
    <h2>Uncompleted</h2>
        <table class="leaderboard-table js-sortable-table">
            <thead>
                <tr>
                    <th>Map Name</th>
                    <th>Type</th>
                </tr>
            </thead>
            <tbody>
                {% for map in uncompletedMaps %}
                    <tr>
                        <td>
                            <a href="{{ path('app_map_times', { 'name': map.name }) }}" class="player-name-link">
                                <strong>{{ map.name }}</strong>
                            </a>
                        </td>
                        <td>
                            {% if map.isLinear %}
                                <span class="badge badge-linear">Linear</span>
                            {% else %}
                                <span class="badge badge-staged">Staged</span>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}

    <h2>Achievements</h2>
    <div class="achievements-grid">
        {% for achievement in achievements %}
            {% set isUnlocked = achievement.key in unlockedKeys %}
            
            <div class="achievement-card {{ isUnlocked ? 'unlocked' : 'locked' }}">
                <div class="achievement-badge-container">
                <img src="{{ asset('images/achievements/' ~ achievement.key ~ '.png') }}" alt="{{ achievement.name }}" class="achievement-img">
                    
                    {% if not isUnlocked %}
                        <div class="lock-overlay">🔒</div>
                    {% endif %}
                </div>
                
                <h3>{{ achievement.name }}</h3>
                <p>{{ achievement.description }}</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}